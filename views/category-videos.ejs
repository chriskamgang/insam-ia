<%- include('layout/header') %>

<section class="page-header">
  <div class="container">
    <a href="/category/<%= category.id %>" class="back-link"><i class="fas fa-arrow-left"></i> Retour a <%= category.name %></a>
    <h1><i class="fas fa-video"></i> Travaux pratiques</h1>
    <p><%= category.name %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if (videos.length > 0) { %>
      <div class="videos-grid">
        <% videos.forEach(video => { %>
          <a href="/video/<%= video.id %>" class="video-card">
            <div class="video-card-thumb">
              <% if (video.thumbnail) { %>
                <img src="/uploads/thumbnails/<%= video.thumbnail %>" alt="<%= video.title %>">
              <% } else { %>
                <div class="video-card-placeholder">
                  <i class="fas fa-play-circle"></i>
                </div>
              <% } %>
            </div>
            <div class="video-card-body">
              <h4><%= video.title %></h4>
              <% if (video.description) { %>
                <p class="video-card-desc"><%= video.description.substring(0, 100) %><%= video.description.length > 100 ? '...' : '' %></p>
              <% } %>
              <div class="video-card-meta">
                <span><i class="fas fa-eye"></i> <%= video.views_count %> vues</span>
                <span><i class="fas fa-calendar"></i> <%= new Date(video.created_at).toLocaleDateString('fr-FR') %></span>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div style="text-align: center; padding: 60px 0;">
        <i class="fas fa-video-slash" style="font-size: 4rem; color: #ccc;"></i>
        <h3 style="margin-top: 20px;">Aucune video dans cette specialite</h3>
        <p style="color: #666;">Les videos seront bientot ajoutees.</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('layout/footer') %>
