<%- include('layout/header') %>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <img src="/images/logo.jpeg" alt="Logo" class="hero-logo">
    <h1><%= settings.hero_title %></h1>
    <p><%= settings.hero_description %></p>
    <a href="/categories" class="btn btn-primary btn-lg">
      <i class="fas fa-play-circle"></i> Explorer les specialites
    </a>
  </div>
</section>

<!-- Hero Media Carousel -->
<% if (heroMedia.length > 0) { %>
<section class="section hero-media-section">
  <div class="container">
    <h2 class="section-title">En images</h2>
    <div class="hero-media-grid">
      <% heroMedia.forEach(media => { %>
        <div class="hero-media-item">
          <% if (media.type === 'video') { %>
            <video class="hero-video" controls preload="metadata">
              <source src="/uploads/images/<%= media.filename %>" type="video/mp4">
            </video>
          <% } else { %>
            <img src="/uploads/images/<%= media.filename %>" alt="<%= media.title || '' %>">
          <% } %>
          <% if (media.title) { %>
            <p class="hero-media-title"><%= media.title %></p>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- Categories Section -->
<% if (categories.length > 0) { %>
<section class="section">
  <div class="container">
    <h2 class="section-title">Nos specialites</h2>
    <div class="categories-grid">
      <% categories.forEach(cat => { %>
        <a href="/category/<%= cat.id %>" class="category-card">
          <div class="category-card-img">
            <% if (cat.image) { %>
              <img src="/uploads/images/<%= cat.image %>" alt="<%= cat.name %>">
            <% } else { %>
              <div class="category-card-placeholder">
                <i class="fas fa-graduation-cap"></i>
              </div>
            <% } %>
          </div>
          <div class="category-card-body">
            <h3><%= cat.name %></h3>
            <% if (cat.description) { %>
              <p><%= cat.description %></p>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- Recent Videos -->
<% if (recentVideos.length > 0) { %>
<section class="section section-alt">
  <div class="container">
    <h2 class="section-title">Videos recentes</h2>
    <div class="videos-grid">
      <% recentVideos.forEach(video => { %>
        <a href="/video/<%= video.id %>" class="video-card">
          <div class="video-card-thumb">
            <% if (video.thumbnail) { %>
              <img src="/uploads/thumbnails/<%= video.thumbnail %>" alt="<%= video.title %>">
            <% } else { %>
              <div class="video-card-placeholder">
                <i class="fas fa-play-circle"></i>
              </div>
            <% } %>
            <span class="video-card-badge"><%= video.category_name %></span>
          </div>
          <div class="video-card-body">
            <h4><%= video.title %></h4>
            <div class="video-card-meta">
              <span><i class="fas fa-eye"></i> <%= video.views_count %> vues</span>
              <span><i class="fas fa-calendar"></i> <%= new Date(video.created_at).toLocaleDateString('fr-FR') %></span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- Empty State -->
<% if (categories.length === 0 && recentVideos.length === 0) { %>
<section class="section">
  <div class="container" style="text-align: center; padding: 60px 0;">
    <i class="fas fa-video" style="font-size: 4rem; color: #ccc; margin-bottom: 20px;"></i>
    <h2>Bienvenue sur <%= settings.site_name %></h2>
    <p style="color: #666;">Les videos seront bientot disponibles. Revenez nous voir !</p>
    <a href="/admin" class="btn btn-primary" style="margin-top: 20px;">
      <i class="fas fa-cog"></i> Configurer le site
    </a>
  </div>
</section>
<% } %>

<%- include('layout/footer') %>
