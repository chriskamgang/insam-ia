  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <img src="/images/logo.jpeg" alt="Logo" class="footer-logo">
          <h3><%= settings.site_name %></h3>
          <p><%= settings.site_subtitle %></p>
        </div>
        <div class="footer-col">
          <h4>Liens rapides</h4>
          <ul>
            <li><a href="/">Accueil</a></li>
            <li><a href="/categories">Specialites</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Contact</h4>
          <% if (settings.contact_email) { %>
            <p><i class="fas fa-envelope"></i> <%= settings.contact_email %></p>
          <% } %>
          <% if (settings.contact_phone) { %>
            <p><i class="fas fa-phone"></i> <%= settings.contact_phone %></p>
          <% } %>
          <% if (settings.address) { %>
            <p><i class="fas fa-map-marker-alt"></i> <%= settings.address %></p>
          <% } %>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= settings.site_name %> - Tous droits reserves</p>
      </div>
    </div>
  </footer>

  <script src="https://vjs.zencdn.net/8.10.0/video.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
