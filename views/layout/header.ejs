<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - ' : '' %><%= settings.site_name %></title>
  <link rel="icon" href="/images/logo.jpeg" type="image/jpeg">
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link href="https://vjs.zencdn.net/8.10.0/video-js.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container navbar-content">
      <a href="/" class="navbar-brand">
        <img src="/images/logo.jpeg" alt="Logo" class="navbar-logo">
        <div>
          <span class="navbar-title"><%= settings.site_name %></span>
          <span class="navbar-subtitle"><%= settings.site_subtitle %></span>
        </div>
      </a>
      <button class="navbar-toggle" onclick="document.querySelector('.navbar-menu').classList.toggle('active')">
        <i class="fas fa-bars"></i>
      </button>
      <ul class="navbar-menu">
        <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>"><i class="fas fa-home"></i> Accueil</a></li>
        <li><a href="/categories" class="<%= currentPath === '/categories' ? 'active' : '' %>"><i class="fas fa-th-large"></i> Specialites</a></li>
        <li><a href="/admin" class="btn-admin"><i class="fas fa-lock"></i> Admin</a></li>
      </ul>
    </div>
  </nav>
