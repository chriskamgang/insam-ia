<%- include('layout/header') %>

<section class="section video-page">
  <div class="container">
    <a href="/category/<%= video.cat_id %>" class="back-link">
      <i class="fas fa-arrow-left"></i> Retour a <%= video.category_name %>
    </a>

    <div class="video-player-wrapper">
      <video id="main-player" class="video-js vjs-big-play-centered vjs-fluid" controls preload="auto"
        data-setup='{"playbackRates": [0.5, 1, 1.5, 2]}'>
        <source src="/uploads/videos/<%= video.filename %>" type="video/mp4">
        <p>Votre navigateur ne supporte pas la lecture video.</p>
      </video>
    </div>

    <div class="video-info">
      <h1><%= video.title %></h1>
      <div class="video-meta">
        <span class="video-category-badge"><%= video.category_name %></span>
        <span><i class="fas fa-eye"></i> <%= video.views_count %> vues</span>
        <span><i class="fas fa-calendar"></i> <%= new Date(video.created_at).toLocaleDateString('fr-FR') %></span>
      </div>
      <% if (video.description) { %>
        <div class="video-description">
          <p><%= video.description %></p>
        </div>
      <% } %>
    </div>

    <!-- Related videos -->
    <% if (relatedVideos.length > 0) { %>
      <div class="related-section">
        <h3>Autres videos - <%= video.category_name %></h3>
        <div class="videos-grid">
          <% relatedVideos.forEach(rv => { %>
            <a href="/video/<%= rv.id %>" class="video-card">
              <div class="video-card-thumb">
                <% if (rv.thumbnail) { %>
                  <img src="/uploads/thumbnails/<%= rv.thumbnail %>" alt="<%= rv.title %>">
                <% } else { %>
                  <div class="video-card-placeholder">
                    <i class="fas fa-play-circle"></i>
                  </div>
                <% } %>
              </div>
              <div class="video-card-body">
                <h4><%= rv.title %></h4>
                <div class="video-card-meta">
                  <span><i class="fas fa-eye"></i> <%= rv.views_count %> vues</span>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</section>

<%- include('layout/footer') %>
