<%- include('layout/header') %>

<section class="page-header">
  <div class="container">
    <a href="/category/<%= category.id %>" class="back-link"><i class="fas fa-arrow-left"></i> Retour a <%= category.name %></a>
    <h1><i class="fas fa-certificate"></i> Certifications gratuites</h1>
    <p><%= category.name %></p>
  </div>
</section>

<!-- Formations depuis InsamTechs -->
<% if (formations && formations.length > 0) { %>
<section class="section">
  <div class="container">
    <h2 class="section-title">Formations disponibles</h2>
    <div class="formations-grid">
      <% formations.forEach(f => { %>
        <div class="formation-card" onclick="document.getElementById('downloadModal').style.display='flex'" style="cursor:pointer">
          <div class="formation-img">
            <% if (f.img) { %>
              <img src="https://admin.insamtechs.com/storage/<%= f.img %>" alt="<%= typeof f.intitule === 'object' ? (f.intitule.fr || f.intitule.en || '') : f.intitule %>">
            <% } else { %>
              <div class="formation-placeholder">
                <i class="fas fa-graduation-cap"></i>
              </div>
            <% } %>
            <% if (f.prix) { %>
              <span class="formation-price">
                <% const prix = typeof f.prix === 'object' ? (f.prix.fr || f.prix.en || 'Gratuit') : f.prix; %>
                <%= prix == 0 || prix === '0' ? 'Gratuit' : prix + ' FCFA' %>
              </span>
            <% } %>
          </div>
          <div class="formation-body">
            <h3>
              <% if (typeof f.intitule === 'object') { %>
                <%= f.intitule.fr || f.intitule.en || 'Sans titre' %>
              <% } else { %>
                <%= f.intitule || 'Sans titre' %>
              <% } %>
            </h3>
            <% if (f.description) { %>
              <p class="formation-desc">
                <% const desc = typeof f.description === 'object' ? (f.description.fr || f.description.en || '') : f.description; %>
                <%= desc.substring(0, 120) %><%= desc.length > 120 ? '...' : '' %>
              </p>
            <% } %>
            <div class="formation-meta">
              <% if (f.chapitres && f.chapitres.length > 0) { %>
                <span><i class="fas fa-list"></i> <%= f.chapitres.length %> chapitre<%= f.chapitres.length > 1 ? 's' : '' %></span>
              <% } %>
              <% if (f.chapitres) { %>
                <% let totalVideos = 0; f.chapitres.forEach(ch => { if(ch.videos) totalVideos += ch.videos.length; }); %>
                <% if (totalVideos > 0) { %>
                  <span><i class="fas fa-video"></i> <%= totalVideos %> video<%= totalVideos > 1 ? 's' : '' %></span>
                <% } %>
              <% } %>
              <% if (f.duree) { %>
                <span><i class="fas fa-clock"></i> <%= f.duree %></span>
              <% } %>
            </div>
            <% if (f.chapitres && f.chapitres.length > 0) { %>
              <div class="formation-chapters">
                <% f.chapitres.slice(0, 3).forEach(ch => { %>
                  <div class="chapter-item">
                    <i class="fas fa-play-circle"></i>
                    <span>
                      <% if (typeof ch.intitule === 'object') { %>
                        <%= ch.intitule.fr || ch.intitule.en || '' %>
                      <% } else { %>
                        <%= ch.intitule || '' %>
                      <% } %>
                    </span>
                    <% if (ch.videos && ch.videos.length > 0) { %>
                      <small>(<%= ch.videos.length %> video<%= ch.videos.length > 1 ? 's' : '' %>)</small>
                    <% } %>
                  </div>
                <% }) %>
                <% if (f.chapitres.length > 3) { %>
                  <div class="chapter-more">+ <%= f.chapitres.length - 3 %> autre<%= (f.chapitres.length - 3) > 1 ? 's' : '' %> chapitre<%= (f.chapitres.length - 3) > 1 ? 's' : '' %></div>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- Certifications externes -->
<% if (certifications.length > 0) { %>
<section class="section section-alt">
  <div class="container">
    <h2 class="section-title">Certifications externes</h2>
    <div class="certifications-grid">
      <% certifications.forEach(cert => { %>
        <div class="cert-card">
          <% if (cert.image) { %>
            <div class="cert-image">
              <img src="/uploads/images/<%= cert.image %>" alt="<%= cert.title %>">
            </div>
          <% } else { %>
            <div class="cert-image cert-placeholder">
              <i class="fas fa-award"></i>
            </div>
          <% } %>
          <div class="cert-body">
            <h3><%= cert.title %></h3>
            <% if (cert.provider) { %>
              <span class="cert-provider"><i class="fas fa-building"></i> <%= cert.provider %></span>
            <% } %>
            <% if (cert.description) { %>
              <p class="cert-desc"><%= cert.description %></p>
            <% } %>
            <% if (cert.url) { %>
              <a href="<%= cert.url %>" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                <i class="fas fa-external-link-alt"></i> Acceder a la certification
              </a>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- Rien du tout -->
<% if ((!formations || formations.length === 0) && certifications.length === 0) { %>
<section class="section">
  <div class="container" style="text-align: center; padding: 60px 0;">
    <i class="fas fa-award" style="font-size: 4rem; color: #ccc;"></i>
    <h3 style="margin-top: 20px;">Aucune certification pour le moment</h3>
    <p style="color: #666;">Les certifications seront bientot ajoutees.</p>
  </div>
</section>
<% } %>

<!-- Modal Telecharger Estuaire Emploie -->
<div id="downloadModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9999; justify-content:center; align-items:center;" onclick="if(event.target===this)this.style.display='none'">
  <div style="background:#fff; border-radius:16px; padding:40px; max-width:500px; width:90%; text-align:center; position:relative;">
    <button onclick="document.getElementById('downloadModal').style.display='none'" style="position:absolute; top:12px; right:16px; background:none; border:none; font-size:24px; cursor:pointer; color:#666;">&times;</button>
    <i class="fas fa-mobile-alt" style="font-size:3rem; color:#1B2A4A; margin-bottom:16px;"></i>
    <h2 style="margin-bottom:8px; color:#1B2A4A;">Telechargez Estuaire Emploie</h2>
    <p style="color:#666; margin-bottom:24px;">Pour acceder a cette formation, telechargez l'application <strong>Estuaire Emploie</strong> disponible gratuitement.</p>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <a href="https://play.google.com/store/apps/details?id=com.estuaireemploi" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:8px; background:#1B2A4A; color:#fff; padding:12px 24px; border-radius:8px; text-decoration:none; font-weight:600;">
        <i class="fab fa-google-play" style="font-size:1.4rem;"></i>
        Google Play
      </a>
      <a href="https://apps.apple.com/app/estuaire-emploie" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:8px; background:#000; color:#fff; padding:12px 24px; border-radius:8px; text-decoration:none; font-weight:600;">
        <i class="fab fa-apple" style="font-size:1.4rem;"></i>
        App Store
      </a>
    </div>
  </div>
</div>

<%- include('layout/footer') %>
