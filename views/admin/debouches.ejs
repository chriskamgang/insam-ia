<%- include('layout') %>

<div class="admin-header">
  <h1><i class="fas fa-briefcase"></i> Gestion des debouches</h1>
  <div style="display:flex;gap:10px;">
    <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'"
      <% if (categories.length === 0) { %>disabled<% } %>>
      <i class="fas fa-plus"></i> Ajouter
    </button>
    <button class="btn btn-primary" style="background:#4285f4;" onclick="document.getElementById('aiModal').style.display='flex'"
      <% if (categories.length === 0) { %>disabled<% } %>>
      <i class="fas fa-robot"></i> Generer avec l'IA
    </button>
  </div>
</div>

<div class="admin-card">
  <% if (debouches.length > 0) { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Icone</th>
        <th>Titre</th>
        <th>Specialite</th>
        <th>Description</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% debouches.forEach(d => { %>
      <tr>
        <td><i class="<%= d.icon %>" style="font-size:20px; color: var(--primary);"></i></td>
        <td><strong><%= d.title %></strong></td>
        <td><span class="badge"><%= d.category_name %></span></td>
        <td><%= d.description ? d.description.substring(0, 60) + '...' : '-' %></td>
        <td class="table-actions">
          <button class="btn btn-sm btn-edit" onclick='editDebouche(<%= JSON.stringify(d) %>)'>
            <i class="fas fa-edit"></i>
          </button>
          <form method="POST" action="/admin/debouches/delete/<%= d.id %>" style="display:inline"
            onsubmit="return confirm('Supprimer ce debouche ?')">
            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p style="text-align:center; padding: 40px; color: #999;">Aucun debouche. Cliquez sur "Ajouter" pour commencer.</p>
  <% } %>
</div>

<!-- Modal Ajouter -->
<div id="addModal" class="modal">
  <div class="modal-content" style="max-height:90vh;overflow-y:auto;">
    <div class="modal-header">
      <h3>Ajouter des debouches</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <div class="form-group">
      <label>Specialite *</label>
      <select id="addCatId" class="form-control" required>
        <option value="">-- Choisir --</option>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div id="addedList"></div>
    <div id="deboucheFormArea">
      <hr style="margin:15px 0;">
      <div class="form-group">
        <label>Titre du metier *</label>
        <input type="text" id="addTitle" class="form-control" required placeholder="Ex: Developpeur Web">
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea id="addDesc" class="form-control" rows="2" placeholder="Description du metier..."></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div class="form-group">
          <label>Icone FontAwesome</label>
          <input type="text" id="addIcon" class="form-control" value="fas fa-briefcase">
        </div>
        <div class="form-group">
          <label>Ordre</label>
          <input type="number" id="addOrder" class="form-control" value="0">
        </div>
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:15px;">
      <button type="button" class="btn btn-primary" style="flex:1;" onclick="saveDebouche()">
        <i class="fas fa-plus"></i> Ajouter et continuer
      </button>
      <button type="button" class="btn btn-primary" style="flex:1;background:var(--success);" onclick="saveDebouche(true)">
        <i class="fas fa-check"></i> Terminer
      </button>
    </div>
  </div>
</div>

<!-- Modal Modifier -->
<div id="editModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Modifier le debouche</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <form id="editForm" method="POST">
      <div class="form-group">
        <label>Specialite *</label>
        <select name="category_id" id="editCatId" class="form-control" required>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Titre du metier *</label>
        <input type="text" name="title" id="editTitle" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" id="editDesc" class="form-control" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>Icone FontAwesome</label>
        <input type="text" name="icon" id="editIcon" class="form-control">
      </div>
      <div class="form-group">
        <label>Ordre</label>
        <input type="number" name="sort_order" id="editOrder" class="form-control">
      </div>
      <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-save"></i> Enregistrer</button>
    </form>
  </div>
</div>

<!-- Modal IA -->
<div id="aiModal" class="modal">
  <div class="modal-content" style="text-align:center;">
    <div class="modal-header">
      <h3><i class="fas fa-robot"></i> Generer les debouches avec l'IA</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <p style="color:#666;margin-bottom:20px;">Choisissez une specialite et l'IA generera automatiquement les debouches professionnels.</p>
    <div class="form-group" style="text-align:left;">
      <label>Specialite *</label>
      <select id="aiCatId" class="form-control">
        <option value="">-- Choisir --</option>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div id="aiStatus" style="display:none;padding:20px;">
      <i class="fas fa-spinner fa-spin" style="font-size:2rem;color:#4285f4;"></i>
      <p style="margin-top:10px;">Gemini genere les debouches...</p>
    </div>
    <div id="aiResult" style="display:none;padding:15px;background:#e8f5e9;border-radius:8px;margin-top:10px;"></div>
    <button id="aiBtn" type="button" class="btn btn-primary btn-block" style="background:#4285f4;margin-top:15px;" onclick="generateDebouches()">
      <i class="fas fa-magic"></i> Generer
    </button>
  </div>
</div>

<script>
let deboucheCount = 0;

function saveDebouche(finish) {
  const catId = document.getElementById('addCatId').value;
  const title = document.getElementById('addTitle').value;
  if (!catId) return alert('Choisissez une specialite');
  if (!title) return alert('Le titre est requis');

  deboucheCount++;
  const data = new URLSearchParams({
    category_id: catId,
    title: title,
    description: document.getElementById('addDesc').value,
    icon: document.getElementById('addIcon').value,
    sort_order: document.getElementById('addOrder').value
  });

  fetch('/admin/debouches/add', { method: 'POST', body: data, headers: {'Content-Type': 'application/x-www-form-urlencoded'}, redirect: 'manual' })
    .then(() => {
      const list = document.getElementById('addedList');
      list.innerHTML += '<div style="padding:8px 12px;background:#e8f5e9;border-radius:6px;margin-bottom:5px;display:flex;align-items:center;gap:8px;"><i class="' + document.getElementById('addIcon').value + '" style="color:var(--primary);"></i><strong>' + title + '</strong> <i class="fas fa-check" style="color:green;margin-left:auto;"></i></div>';

      document.getElementById('addTitle').value = '';
      document.getElementById('addDesc').value = '';
      document.getElementById('addOrder').value = deboucheCount;

      if (finish) {
        window.location.reload();
      }
    });
}

function generateDebouches() {
  const catId = document.getElementById('aiCatId').value;
  if (!catId) return alert('Choisissez une specialite');

  document.getElementById('aiBtn').disabled = true;
  document.getElementById('aiStatus').style.display = 'block';
  document.getElementById('aiResult').style.display = 'none';

  fetch('/admin/debouches/generate', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'category_id=' + catId
  })
  .then(r => r.json())
  .then(data => {
    document.getElementById('aiStatus').style.display = 'none';
    if (data.success) {
      document.getElementById('aiResult').style.display = 'block';
      document.getElementById('aiResult').innerHTML = '<i class="fas fa-check-circle" style="color:green;font-size:1.5rem;"></i><p style="margin-top:8px;"><strong>' + data.count + ' debouches</strong> generes avec succes !</p>';
      setTimeout(() => window.location.reload(), 1500);
    } else {
      document.getElementById('aiBtn').disabled = false;
      alert('Erreur: ' + (data.error || 'Erreur inconnue'));
    }
  })
  .catch(err => {
    document.getElementById('aiStatus').style.display = 'none';
    document.getElementById('aiBtn').disabled = false;
    alert('Erreur: ' + err.message);
  });
}

function editDebouche(d) {
  document.getElementById('editForm').action = '/admin/debouches/edit/' + d.id;
  document.getElementById('editCatId').value = d.category_id;
  document.getElementById('editTitle').value = d.title;
  document.getElementById('editDesc').value = d.description || '';
  document.getElementById('editIcon').value = d.icon;
  document.getElementById('editOrder').value = d.sort_order;
  document.getElementById('editModal').style.display = 'flex';
}
</script>

<%- include('layout-end') %>
