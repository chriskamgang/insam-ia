<%- include('layout') %>

<div class="admin-header">
  <h1><i class="fas fa-images"></i> Media de l'accueil</h1>
  <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
    <i class="fas fa-plus"></i> Ajouter
  </button>
</div>

<p class="admin-hint">Ces images et videos apparaissent sur la page d'accueil du site.</p>

<div class="admin-card">
  <% if (heroMedia.length > 0) { %>
  <div class="hero-admin-grid">
    <% heroMedia.forEach(m => { %>
    <div class="hero-admin-item">
      <% if (m.type === 'image') { %>
        <img src="/uploads/images/<%= m.filename %>" alt="<%= m.title || '' %>">
      <% } else { %>
        <video src="/uploads/images/<%= m.filename %>" controls></video>
      <% } %>
      <div class="hero-admin-info">
        <span class="badge"><%= m.type %></span>
        <span><%= m.title || 'Sans titre' %></span>
        <form method="POST" action="/admin/hero/delete/<%= m.id %>"
          onsubmit="return confirm('Supprimer ce media ?')">
          <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
        </form>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
    <p style="text-align:center; padding: 40px; color: #999;">Aucun media. Ajoutez des photos/videos pour la page d'accueil.</p>
  <% } %>
</div>

<!-- Modal Ajouter -->
<div id="addModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Ajouter un media</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <form method="POST" action="/admin/hero/add" enctype="multipart/form-data">
      <div class="form-group">
        <label>Type</label>
        <select name="type" class="form-control">
          <option value="image">Image</option>
          <option value="video">Video</option>
        </select>
      </div>
      <div class="form-group">
        <label>Fichier *</label>
        <input type="file" name="file" class="form-control" accept="image/*,video/*" required>
      </div>
      <div class="form-group">
        <label>Titre (optionnel)</label>
        <input type="text" name="title" class="form-control">
      </div>
      <div class="form-group">
        <label>Ordre d'affichage</label>
        <input type="number" name="sort_order" class="form-control" value="0">
      </div>
      <button type="submit" class="btn btn-primary btn-block">
        <i class="fas fa-save"></i> Enregistrer
      </button>
    </form>
  </div>
</div>

<%- include('layout-end') %>
