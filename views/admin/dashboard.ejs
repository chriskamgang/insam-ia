<%- include('layout') %>

<div class="admin-header">
  <h1><i class="fas fa-tachometer-alt"></i> Tableau de bord</h1>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon" style="background: #1B2A4A;"><i class="fas fa-folder"></i></div>
    <div class="stat-info">
      <h3><%= stats.categories %></h3>
      <p>Specialites</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background: #F5A623;"><i class="fas fa-video"></i></div>
    <div class="stat-info">
      <h3><%= stats.videos %></h3>
      <p>Videos</p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background: #27ae60;"><i class="fas fa-eye"></i></div>
    <div class="stat-info">
      <h3><%= stats.totalViews %></h3>
      <p>Vues totales</p>
    </div>
  </div>
</div>

<% if (recentVideos.length > 0) { %>
<div class="admin-card">
  <h3><i class="fas fa-clock"></i> Videos recentes</h3>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Titre</th>
        <th>Specialite</th>
        <th>Vues</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% recentVideos.forEach(v => { %>
      <tr>
        <td><%= v.title %></td>
        <td><span class="badge"><%= v.category_name %></span></td>
        <td><%= v.views_count %></td>
        <td><%= new Date(v.created_at).toLocaleDateString('fr-FR') %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<%- include('layout-end') %>
