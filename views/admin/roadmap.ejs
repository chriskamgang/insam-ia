<%- include('layout') %>

<div class="admin-header">
  <h1><i class="fas fa-route"></i> Gestion des roadmaps</h1>
  <div style="display:flex;gap:10px;">
    <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'"
      <% if (categories.length === 0) { %>disabled<% } %>>
      <i class="fas fa-plus"></i> Ajouter
    </button>
    <button class="btn btn-primary" style="background:#4285f4;" onclick="document.getElementById('aiModal').style.display='flex'"
      <% if (categories.length === 0) { %>disabled<% } %>>
      <i class="fas fa-robot"></i> Generer avec l'IA
    </button>
  </div>
</div>

<div class="admin-card">
  <% if (steps.length > 0) { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>N</th>
        <th>Titre</th>
        <th>Specialite</th>
        <th>Niveau</th>
        <th>Duree</th>
        <th>Competences</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% steps.forEach(s => { %>
      <tr>
        <td>
          <span style="display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:50%;background:<%= s.color %>;color:white;font-size:12px;font-weight:700;">
            <%= s.step_number %>
          </span>
        </td>
        <td><strong><%= s.title %></strong></td>
        <td><span class="badge"><%= s.category_name %></span></td>
        <td><%= s.level %></td>
        <td><%= s.duration || '-' %></td>
        <td><%= s.skills ? s.skills.substring(0, 40) + '...' : '-' %></td>
        <td class="table-actions">
          <button class="btn btn-sm btn-edit" onclick='editStep(<%= JSON.stringify(s) %>)'>
            <i class="fas fa-edit"></i>
          </button>
          <form method="POST" action="/admin/roadmap/delete/<%= s.id %>" style="display:inline"
            onsubmit="return confirm('Supprimer cette etape ?')">
            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p style="text-align:center; padding: 40px; color: #999;">Aucune etape. Cliquez sur "Ajouter" pour creer un roadmap.</p>
  <% } %>
</div>

<!-- Modal Ajouter -->
<div id="addModal" class="modal">
  <div class="modal-content" style="max-height:90vh;overflow-y:auto;">
    <div class="modal-header">
      <h3>Ajouter des etapes</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <div class="form-group">
      <label>Specialite *</label>
      <select id="addCatId" class="form-control" required>
        <option value="">-- Choisir --</option>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div id="addedStepsList"></div>
    <div id="stepFormArea">
      <hr style="margin:15px 0;">
      <h4 id="stepFormTitle" style="margin-bottom:10px;">Etape <span id="stepCount">1</span></h4>
      <div class="form-group">
        <label>Titre *</label>
        <input type="text" id="addTitle" class="form-control" required placeholder="Ex: Les fondamentaux">
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea id="addDesc" class="form-control" rows="2" placeholder="Ce que l'etudiant apprendra..."></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div class="form-group">
          <label>Niveau</label>
          <select id="addLevel" class="form-control">
            <option value="Debutant">Debutant</option>
            <option value="Intermediaire">Intermediaire</option>
            <option value="Avance">Avance</option>
            <option value="Expert">Expert</option>
          </select>
        </div>
        <div class="form-group">
          <label>Duree estimee</label>
          <input type="text" id="addDuration" class="form-control" placeholder="Ex: 3 mois">
        </div>
      </div>
      <div class="form-group">
        <label>Competences (separees par virgules)</label>
        <input type="text" id="addSkills" class="form-control" placeholder="Ex: HTML, CSS, JavaScript">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <div class="form-group">
          <label>Icone</label>
          <input type="text" id="addIcon" class="form-control" value="fas fa-book">
        </div>
        <div class="form-group">
          <label>Couleur</label>
          <input type="color" id="addColor" class="form-control" value="#1B2A4A" style="height:45px;padding:5px;">
        </div>
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:15px;">
      <button type="button" class="btn btn-primary" style="flex:1;" onclick="saveStep()">
        <i class="fas fa-plus"></i> Ajouter et continuer
      </button>
      <button type="button" class="btn btn-primary" style="flex:1;background:var(--success);" onclick="saveStep(true)">
        <i class="fas fa-check"></i> Terminer
      </button>
    </div>
  </div>
</div>

<!-- Modal Modifier -->
<div id="editModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Modifier l'etape</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <form id="editForm" method="POST">
      <div class="form-group">
        <label>Specialite *</label>
        <select name="category_id" id="editCatId" class="form-control" required>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Numero de l'etape *</label>
        <input type="number" name="step_number" id="editStepNum" class="form-control" required min="1">
      </div>
      <div class="form-group">
        <label>Titre *</label>
        <input type="text" name="title" id="editTitle" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" id="editDesc" class="form-control" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>Niveau</label>
        <select name="level" id="editLevel" class="form-control">
          <option value="Debutant">Debutant</option>
          <option value="Intermediaire">Intermediaire</option>
          <option value="Avance">Avance</option>
          <option value="Expert">Expert</option>
        </select>
      </div>
      <div class="form-group">
        <label>Duree estimee</label>
        <input type="text" name="duration" id="editDuration" class="form-control">
      </div>
      <div class="form-group">
        <label>Competences</label>
        <input type="text" name="skills" id="editSkills" class="form-control">
      </div>
      <div class="form-group">
        <label>Icone FontAwesome</label>
        <input type="text" name="icon" id="editIcon" class="form-control">
      </div>
      <div class="form-group">
        <label>Couleur</label>
        <input type="color" name="color" id="editColor" class="form-control" style="height:45px;padding:5px;">
      </div>
      <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-save"></i> Enregistrer</button>
    </form>
  </div>
</div>

<!-- Modal IA -->
<div id="aiModal" class="modal">
  <div class="modal-content" style="text-align:center;">
    <div class="modal-header">
      <h3><i class="fas fa-robot"></i> Generer le roadmap avec l'IA</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <p style="color:#666;margin-bottom:20px;">Choisissez une specialite et l'IA generera automatiquement les etapes du roadmap.</p>
    <div class="form-group" style="text-align:left;">
      <label>Specialite *</label>
      <select id="aiCatId" class="form-control">
        <option value="">-- Choisir --</option>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div id="aiStatus" style="display:none;padding:20px;">
      <i class="fas fa-spinner fa-spin" style="font-size:2rem;color:#4285f4;"></i>
      <p style="margin-top:10px;">Gemini genere le roadmap...</p>
    </div>
    <div id="aiResult" style="display:none;padding:15px;background:#e8f5e9;border-radius:8px;margin-top:10px;"></div>
    <button id="aiBtn" type="button" class="btn btn-primary btn-block" style="background:#4285f4;margin-top:15px;" onclick="generateRoadmap()">
      <i class="fas fa-magic"></i> Generer
    </button>
  </div>
</div>

<script>
let stepCounter = 1;

function saveStep(finish) {
  const catId = document.getElementById('addCatId').value;
  const title = document.getElementById('addTitle').value;
  if (!catId) return alert('Choisissez une specialite');
  if (!title) return alert('Le titre est requis');

  const data = new URLSearchParams({
    category_id: catId,
    step_number: stepCounter,
    title: title,
    description: document.getElementById('addDesc').value,
    level: document.getElementById('addLevel').value,
    duration: document.getElementById('addDuration').value,
    skills: document.getElementById('addSkills').value,
    icon: document.getElementById('addIcon').value,
    color: document.getElementById('addColor').value
  });

  fetch('/admin/roadmap/add', { method: 'POST', body: data, headers: {'Content-Type': 'application/x-www-form-urlencoded'}, redirect: 'manual' })
    .then(() => {
      const list = document.getElementById('addedStepsList');
      list.innerHTML += '<div style="padding:8px 12px;background:#e8f5e9;border-radius:6px;margin-bottom:5px;display:flex;align-items:center;gap:8px;"><span style="display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;background:' + document.getElementById('addColor').value + ';color:white;font-size:11px;font-weight:700;">' + stepCounter + '</span><strong>' + title + '</strong> <span style="color:#888;margin-left:auto;">' + document.getElementById('addLevel').value + '</span></div>';

      stepCounter++;
      document.getElementById('stepCount').textContent = stepCounter;
      document.getElementById('addTitle').value = '';
      document.getElementById('addDesc').value = '';
      document.getElementById('addDuration').value = '';
      document.getElementById('addSkills').value = '';

      if (finish) {
        window.location.reload();
      }
    });
}

function generateRoadmap() {
  const catId = document.getElementById('aiCatId').value;
  if (!catId) return alert('Choisissez une specialite');

  document.getElementById('aiBtn').disabled = true;
  document.getElementById('aiStatus').style.display = 'block';
  document.getElementById('aiResult').style.display = 'none';

  fetch('/admin/roadmap/generate', {
    method: 'POST',
    headers: {'Content-Type': 'application/x-www-form-urlencoded'},
    body: 'category_id=' + catId
  })
  .then(r => r.json())
  .then(data => {
    document.getElementById('aiStatus').style.display = 'none';
    if (data.success) {
      document.getElementById('aiResult').style.display = 'block';
      document.getElementById('aiResult').innerHTML = '<i class="fas fa-check-circle" style="color:green;font-size:1.5rem;"></i><p style="margin-top:8px;"><strong>' + data.count + ' etapes</strong> generees avec succes !</p>';
      setTimeout(() => window.location.reload(), 1500);
    } else {
      document.getElementById('aiBtn').disabled = false;
      alert('Erreur: ' + (data.error || 'Erreur inconnue'));
    }
  })
  .catch(err => {
    document.getElementById('aiStatus').style.display = 'none';
    document.getElementById('aiBtn').disabled = false;
    alert('Erreur: ' + err.message);
  });
}

function editStep(s) {
  document.getElementById('editForm').action = '/admin/roadmap/edit/' + s.id;
  document.getElementById('editCatId').value = s.category_id;
  document.getElementById('editStepNum').value = s.step_number;
  document.getElementById('editTitle').value = s.title;
  document.getElementById('editDesc').value = s.description || '';
  document.getElementById('editLevel').value = s.level;
  document.getElementById('editDuration').value = s.duration || '';
  document.getElementById('editSkills').value = s.skills || '';
  document.getElementById('editIcon').value = s.icon;
  document.getElementById('editColor').value = s.color;
  document.getElementById('editModal').style.display = 'flex';
}
</script>

<%- include('layout-end') %>
