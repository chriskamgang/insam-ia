<%- include('layout') %>

<div class="admin-header">
  <h1><i class="fas fa-folder"></i> Gestion des specialites</h1>
  <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
    <i class="fas fa-plus"></i> Ajouter
  </button>
</div>

<div class="admin-card">
  <% if (categories.length > 0) { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Image</th>
        <th>Nom</th>
        <th>Description</th>
        <th>Videos</th>
        <th>Ordre</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% categories.forEach(cat => { %>
      <tr>
        <td>
          <% if (cat.image) { %>
            <img src="/uploads/images/<%= cat.image %>" class="table-thumb">
          <% } else { %>
            <div class="table-thumb-placeholder"><i class="fas fa-image"></i></div>
          <% } %>
        </td>
        <td><strong><%= cat.name %></strong></td>
        <td><%= cat.description || '-' %></td>
        <td><span class="badge"><%= cat.video_count %></span></td>
        <td><%= cat.sort_order %></td>
        <td class="table-actions">
          <button class="btn btn-sm btn-edit" onclick="editCategory(<%= JSON.stringify(cat) %>)">
            <i class="fas fa-edit"></i>
          </button>
          <form method="POST" action="/admin/categories/delete/<%= cat.id %>" style="display:inline"
            onsubmit="return confirm('Supprimer cette specialite et toutes ses videos ?')">
            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p style="text-align:center; padding: 40px; color: #999;">Aucune specialite. Cliquez sur "Ajouter" pour commencer.</p>
  <% } %>
</div>

<!-- Modal Ajouter -->
<div id="addModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Ajouter une specialite</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <form method="POST" action="/admin/categories/add" enctype="multipart/form-data">
      <div class="form-group">
        <label>Nom de la specialite *</label>
        <input type="text" name="name" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" class="form-control" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>Image</label>
        <input type="file" name="image" class="form-control" accept="image/*">
      </div>
      <div class="form-group">
        <label>Slug API InsamTechs (pour recuperer les formations)</label>
        <input type="text" name="api_slug" class="form-control" placeholder="Ex: informatique-xYz123">
        <small style="color:var(--gray);">Slug de la categorie dans l'API Laravel InsamTechs</small>
      </div>
      <div class="form-group">
        <label>Ordre d'affichage</label>
        <input type="number" name="sort_order" class="form-control" value="0">
      </div>
      <button type="submit" class="btn btn-primary btn-block">
        <i class="fas fa-save"></i> Enregistrer
      </button>
    </form>
  </div>
</div>

<!-- Modal Modifier -->
<div id="editModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Modifier la specialite</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <form id="editForm" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Nom de la specialite *</label>
        <input type="text" name="name" id="editName" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" id="editDesc" class="form-control" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>Nouvelle image (laisser vide pour garder l'actuelle)</label>
        <input type="file" name="image" class="form-control" accept="image/*">
      </div>
      <div class="form-group">
        <label>Slug API InsamTechs</label>
        <input type="text" name="api_slug" id="editApiSlug" class="form-control">
      </div>
      <div class="form-group">
        <label>Ordre d'affichage</label>
        <input type="number" name="sort_order" id="editOrder" class="form-control">
      </div>
      <button type="submit" class="btn btn-primary btn-block">
        <i class="fas fa-save"></i> Enregistrer
      </button>
    </form>
  </div>
</div>

<script>
function editCategory(cat) {
  document.getElementById('editForm').action = '/admin/categories/edit/' + cat.id;
  document.getElementById('editApiSlug').value = cat.api_slug || '';
  document.getElementById('editName').value = cat.name;
  document.getElementById('editDesc').value = cat.description || '';
  document.getElementById('editOrder').value = cat.sort_order;
  document.getElementById('editModal').style.display = 'flex';
}
</script>

<%- include('layout-end') %>
