<%- include('layout') %>

<div class="admin-header">
  <h1><i class="fas fa-video"></i> Gestion des videos</h1>
  <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'"
    <% if (categories.length === 0) { %>disabled title="Ajoutez d'abord une specialite"<% } %>>
    <i class="fas fa-plus"></i> Ajouter une video
  </button>
</div>

<% if (categories.length === 0) { %>
<div class="alert alert-error">
  <i class="fas fa-exclamation-triangle"></i> Vous devez d'abord <a href="/admin/categories">creer une specialite</a> avant d'ajouter des videos.
</div>
<% } %>

<div class="admin-card">
  <% if (videos.length > 0) { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Titre</th>
        <th>Specialite</th>
        <th>Vues</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% videos.forEach(v => { %>
      <tr>
        <td><strong><%= v.title %></strong></td>
        <td><span class="badge"><%= v.category_name %></span></td>
        <td><%= v.views_count %></td>
        <td><%= new Date(v.created_at).toLocaleDateString('fr-FR') %></td>
        <td class="table-actions">
          <a href="/video/<%= v.id %>" target="_blank" class="btn btn-sm btn-view">
            <i class="fas fa-play"></i>
          </a>
          <button class="btn btn-sm btn-edit" onclick="editVideo(<%= JSON.stringify({id:v.id, title:v.title, description:v.description, category_id:v.category_id}) %>)">
            <i class="fas fa-edit"></i>
          </button>
          <form method="POST" action="/admin/videos/delete/<%= v.id %>" style="display:inline"
            onsubmit="return confirm('Supprimer cette video ?')">
            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p style="text-align:center; padding: 40px; color: #999;">Aucune video. Cliquez sur "Ajouter" pour commencer.</p>
  <% } %>
</div>

<!-- Modal Ajouter -->
<div id="addModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Ajouter une video</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <form method="POST" action="/admin/videos/add" enctype="multipart/form-data">
      <div class="form-group">
        <label>Titre *</label>
        <input type="text" name="title" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Specialite *</label>
        <select name="category_id" class="form-control" required>
          <option value="">-- Choisir --</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" class="form-control" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>Fichier video * (max 500MB)</label>
        <input type="file" name="video" class="form-control" accept="video/*" required>
        <div class="upload-progress" id="uploadProgress" style="display:none;">
          <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
          <span id="progressText">0%</span>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block" id="uploadBtn">
        <i class="fas fa-upload"></i> Uploader la video
      </button>
    </form>
  </div>
</div>

<!-- Modal Modifier -->
<div id="editModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Modifier la video</h3>
      <button class="modal-close" onclick="this.closest('.modal').style.display='none'">&times;</button>
    </div>
    <form id="editForm" method="POST">
      <div class="form-group">
        <label>Titre *</label>
        <input type="text" name="title" id="editTitle" class="form-control" required>
      </div>
      <div class="form-group">
        <label>Specialite *</label>
        <select name="category_id" id="editCategory" class="form-control" required>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" id="editDescription" class="form-control" rows="3"></textarea>
      </div>
      <button type="submit" class="btn btn-primary btn-block">
        <i class="fas fa-save"></i> Enregistrer
      </button>
    </form>
  </div>
</div>

<script>
function editVideo(v) {
  document.getElementById('editForm').action = '/admin/videos/edit/' + v.id;
  document.getElementById('editTitle').value = v.title;
  document.getElementById('editDescription').value = v.description || '';
  document.getElementById('editCategory').value = v.category_id;
  document.getElementById('editModal').style.display = 'flex';
}

// Upload progress
document.querySelector('#addModal form').addEventListener('submit', function(e) {
  const fileInput = this.querySelector('input[type="file"]');
  if (!fileInput.files.length) return;

  e.preventDefault();
  const formData = new FormData(this);
  const xhr = new XMLHttpRequest();

  document.getElementById('uploadProgress').style.display = 'flex';
  document.getElementById('uploadBtn').disabled = true;
  document.getElementById('uploadBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Upload en cours...';

  xhr.upload.addEventListener('progress', function(e) {
    if (e.lengthComputable) {
      const pct = Math.round((e.loaded / e.total) * 100);
      document.getElementById('progressFill').style.width = pct + '%';
      document.getElementById('progressText').textContent = pct + '%';
    }
  });

  xhr.addEventListener('load', function() {
    window.location.href = '/admin/videos';
  });

  xhr.addEventListener('error', function() {
    alert('Erreur lors de l\'upload');
    document.getElementById('uploadBtn').disabled = false;
    document.getElementById('uploadBtn').innerHTML = '<i class="fas fa-upload"></i> Uploader la video';
  });

  xhr.open('POST', '/admin/videos/add');
  xhr.send(formData);
});
</script>

<%- include('layout-end') %>
