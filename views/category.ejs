<%- include('layout/header') %>

<section class="page-header">
  <div class="container">
    <a href="/categories" class="back-link"><i class="fas fa-arrow-left"></i> Toutes les specialites</a>
    <h1><%= category.name %></h1>
    <% if (category.description) { %>
      <p><%= category.description %></p>
    <% } %>
  </div>
</section>

<!-- Action Buttons -->
<section class="section">
  <div class="container">
    <div class="speciality-actions three-cols">
      <a href="/category/<%= category.id %>/roadmap" class="action-card action-roadmap">
        <div class="action-icon"><i class="fas fa-route"></i></div>
        <div class="action-info">
          <h3>Roadmap</h3>
          <p><%= roadmapCount %> etape<%= roadmapCount > 1 ? 's' : '' %> du parcours</p>
        </div>
        <i class="fas fa-arrow-right action-arrow"></i>
      </a>

      <a href="/category/<%= category.id %>/certifications" class="action-card action-cert">
        <div class="action-icon"><i class="fas fa-certificate"></i></div>
        <div class="action-info">
          <h3>Certifications gratuites</h3>
          <p><%= certCount %> certification<%= certCount > 1 ? 's' : '' %> disponible<%= certCount > 1 ? 's' : '' %></p>
        </div>
        <i class="fas fa-arrow-right action-arrow"></i>
      </a>

      <a href="/category/<%= category.id %>/videos" class="action-card action-tp">
        <div class="action-icon"><i class="fas fa-video"></i></div>
        <div class="action-info">
          <h3>Travaux pratiques (TP)</h3>
          <p><%= videoCount %> video<%= videoCount > 1 ? 's' : '' %> disponible<%= videoCount > 1 ? 's' : '' %></p>
        </div>
        <i class="fas fa-arrow-right action-arrow"></i>
      </a>
    </div>
  </div>
</section>

<!-- Debouches -->
<section class="section section-alt">
  <div class="container">
    <h2 class="section-title">Debouches professionnels</h2>
    <% if (debouches.length > 0) { %>
      <div class="debouches-grid">
        <% debouches.forEach(d => { %>
          <div class="debouche-card">
            <div class="debouche-icon"><i class="<%= d.icon %>"></i></div>
            <h4><%= d.title %></h4>
            <% if (d.description) { %>
              <p><%= d.description %></p>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div style="text-align: center; padding: 40px 0;">
        <i class="fas fa-info-circle" style="font-size: 3rem; color: #ccc;"></i>
        <h3 style="margin-top: 15px; color: #999;">Debouches a venir</h3>
        <p style="color: #999;">Les informations sur les debouches seront bientot disponibles.</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('layout/footer') %>
