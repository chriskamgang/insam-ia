<%- include('layout/header') %>

<section class="page-header">
  <div class="container">
    <a href="/category/<%= category.id %>" class="back-link"><i class="fas fa-arrow-left"></i> Retour a <%= category.name %></a>
    <h1><i class="fas fa-route"></i> Roadmap - Parcours de formation</h1>
    <p><%= category.name %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if (steps.length > 0) { %>

      <!-- Progress bar -->
      <div class="roadmap-progress">
        <div class="roadmap-progress-bar">
          <% steps.forEach((step, i) => { %>
            <div class="roadmap-progress-dot <%= i === 0 ? 'active' : '' %>" style="left: <%= (i / (steps.length - 1)) * 100 %>%">
              <span><%= step.step_number %></span>
            </div>
          <% }) %>
          <div class="roadmap-progress-line"></div>
        </div>
      </div>

      <!-- Timeline -->
      <div class="roadmap-timeline">
        <% steps.forEach((step, i) => { %>
          <div class="roadmap-step <%= i % 2 === 0 ? 'step-left' : 'step-right' %>">
            <div class="step-connector">
              <div class="step-number" style="background: <%= step.color %>;">
                <i class="<%= step.icon %>"></i>
              </div>
              <% if (i < steps.length - 1) { %>
                <div class="step-line"></div>
              <% } %>
            </div>
            <div class="step-card">
              <div class="step-header">
                <span class="step-badge" style="background: <%= step.color %>;">Etape <%= step.step_number %></span>
                <span class="step-level"><i class="fas fa-signal"></i> <%= step.level %></span>
              </div>
              <h3><%= step.title %></h3>
              <% if (step.description) { %>
                <p class="step-desc"><%= step.description %></p>
              <% } %>
              <div class="step-meta">
                <% if (step.duration) { %>
                  <span class="step-duration"><i class="fas fa-clock"></i> <%= step.duration %></span>
                <% } %>
              </div>
              <% if (step.skills) { %>
                <div class="step-skills">
                  <% step.skills.split(',').forEach(skill => { %>
                    <span class="skill-tag"><%= skill.trim() %></span>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Final -->
      <div class="roadmap-final">
        <div class="roadmap-final-icon">
          <i class="fas fa-trophy"></i>
        </div>
        <h3>Pret pour le monde professionnel !</h3>
        <p>Vous avez complete le parcours <%= category.name %></p>
        <div class="roadmap-final-actions">
          <a href="/category/<%= category.id %>/certifications" class="btn btn-primary">
            <i class="fas fa-certificate"></i> Voir les certifications
          </a>
          <a href="/category/<%= category.id %>/videos" class="btn btn-primary" style="background: var(--primary); color: white;">
            <i class="fas fa-video"></i> Voir les TP
          </a>
        </div>
      </div>

    <% } else { %>
      <div style="text-align: center; padding: 60px 0;">
        <i class="fas fa-route" style="font-size: 4rem; color: #ccc;"></i>
        <h3 style="margin-top: 20px;">Roadmap en cours de creation</h3>
        <p style="color: #666;">Le parcours de formation sera bientot disponible.</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('layout/footer') %>
